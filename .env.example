# Copia este archivo como .env y pon tus valores reales
# NUNCA subas el archivo .env a GitHub (ya está en .gitignore)

# Clave secreta de Flask (cámbiala por una cadena larga y aleatoria en producción)
# Genera una con: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-una-clave-aleatoria-larga

# URL de conexión a PostgreSQL (la da Neon / Render)
# Formato: postgresql://usuario:password@host:puerto/dbname?sslmode=require
DATABASE_URL=postgresql://usuario:password@host.determinado.neon.tech/dbname?sslmode=require
